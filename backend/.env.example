# Backend environment variables
# Copy this file to .env and fill in your values

PORT=3001
JWT_SECRET=change_this_to_a_strong_random_secret

# Local MongoDB (recommended for development)
MONGODB_URI=mongodb://localhost:27017/placement_portal

# OR MongoDB Atlas (for production/cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/placement_portal?retryWrites=true&w=majority

NODE_ENV=development
